# ─── App ──────────────────────────────────────────────
NEXT_PUBLIC_SITE_URL=https://your-domain.vercel.app
NEXT_PUBLIC_CURRENCY=ETB

# ─── Chapa (Ethiopian payment gateway) ───────────────
# Get keys at https://dashboard.chapa.co
# Telebirr, CBEBirr, Amole, M-Pesa all come via Chapa
CHAPA_SECRET_KEY=CHASECK_replace_me
CHAPA_WEBHOOK_SECRET=replace_me

# ─── Supabase ─────────────────────────────────────────
NEXT_PUBLIC_SUPABASE_URL=https://replace-me.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=replace_me
SUPABASE_SERVICE_ROLE_KEY=replace_me

# ─── Contact form delivery (pick one) ─────────────────
# Option A: Formspree
FORMSPREE_ENDPOINT=https://formspree.io/f/replace_me
# Option B: Resend
RESEND_API_KEY=re_replace_me
CONTACT_TO_EMAIL=studio@example.com

# ─── Optional Sanity CMS ──────────────────────────────
NEXT_PUBLIC_SANITY_PROJECT_ID=replace_me
NEXT_PUBLIC_SANITY_DATASET=production
SANITY_API_READ_TOKEN=replace_me
